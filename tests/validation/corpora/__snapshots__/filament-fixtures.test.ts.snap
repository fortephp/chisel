    'offIcon' => null,
    'onColor' => 'primary',
    'onIcon' => null,
])

<button
  x-data="{ state: {{ $state }} }"
  x-bind:aria-checked="state?.toString()"
  x-on:click="state = !state"
  x-bind:class="
        state ? @js(Arr::toCssClasses([
                    'fi-toggle-on',
                    ...\\Filament\\Support\\get_component_color_classes(ToggleComponent::class, $onColor),
                ])) : @js(Arr::toCssClasses([
