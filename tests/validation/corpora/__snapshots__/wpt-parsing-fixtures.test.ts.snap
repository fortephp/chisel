<script src="/resources/testharness.js"></script>
<script src="/resources/testharnessreport.js"></script>
<div id="log"></div>
<div id="test">
  <svg>
    <altglyph />
    <altglyphdef />
    <altglyphitem />
    <animatecolor />
    <animatemotion />
    <animatetransform />
    <clippath />
    <feblend />
